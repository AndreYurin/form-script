{
  "name": "@form-script/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx ../node_modules/@mikro-orm/cli/cli.js migration:up",
    "db:generate": "tsx ../node_modules/@mikro-orm/cli/cli.js migration:create",
    "db:seed": "tsx src/db/seed.ts",
    "db:migrate-json": "tsx scripts/migrate-json-to-db.ts"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.4.0",
    "@mikro-orm/libsql": "^6.4.0",
    "@mikro-orm/migrations": "^6.4.0",
    "@mikro-orm/reflection": "^6.6.13",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.4.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/mikro-orm.config.ts",
      "./dist/mikro-orm.config.js"
    ]
  }
}
